# Neon Postgres (auto-provisioned via Vercel Marketplace)
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/arrodes?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.neon.tech/arrodes?sslmode=require"

# Read-only MCP (Cursor `.cursor/mcp.json` runs tools/mcp/run-postgres-mcp.ts).
# Prefer a dedicated Neon read-only role; falls back to DATABASE_URL_UNPOOLED then DATABASE_URL.
ARRODES_MCP_DATABASE_URL="postgresql://readonly:pass@ep-xxx.neon.tech/arrodes?sslmode=require&channel_binding=require"

# Vercel AI Gateway — unified provider access, zero-markup PAYG.
# Unused by the current ingestion pipeline (which wires providers directly);
# leave populated if the chat route (ticket 010) will route through Gateway.
AI_GATEWAY_API_KEY=""

# Direct provider keys — REQUIRED for ingestion/eval scripts.
DEEPSEEK_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# Ingestion model IDs. Both bare ("deepseek-v4-flash") and gateway-style
# ("deepseek/deepseek-v4-flash") formats work — scripts strip the provider
# prefix before handing the ID to the provider SDK.
INGEST_CONTEXT_MODEL="deepseek-v4-flash"
INGEST_SUMMARY_MODEL="deepseek-v4-pro"
INGEST_EMBED_MODEL="text-embedding-3-small"
CHAT_MODEL="google/gemini-2.5-flash"
