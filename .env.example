# Neon Postgres (auto-provisioned via Vercel Marketplace)
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/arrodes?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.neon.tech/arrodes?sslmode=require"

# Vercel AI Gateway — unified provider access, zero-markup PAYG
AI_GATEWAY_API_KEY=""

# Optional direct provider keys (fallback if not using AI Gateway)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# Ingestion model overrides (default: anthropic/claude-haiku-4-5 for context, openai/text-embedding-3-small for embed)
INGEST_CONTEXT_MODEL="anthropic/claude-haiku-4-5"
INGEST_EMBED_MODEL="openai/text-embedding-3-small"
CHAT_MODEL="anthropic/claude-sonnet-4-6"
