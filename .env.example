# Neon Postgres (auto-provisioned via Vercel Marketplace)
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/arrodes?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.neon.tech/arrodes?sslmode=require"

# Vercel AI Gateway — unified provider access, zero-markup PAYG.
# Unused by the current ingestion pipeline (which wires providers directly);
# leave populated if the chat route (ticket 010) will route through Gateway.
AI_GATEWAY_API_KEY=""

# Direct provider keys — REQUIRED for `pnpm ingest --phase chunks`.
# Context model hits Anthropic; embed model hits OpenAI.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# Ingestion model IDs. Both bare ("claude-haiku-4-5") and gateway-style
# ("anthropic/claude-haiku-4-5") formats work — the ingest script strips the
# provider prefix before handing the ID to the provider SDK.
INGEST_CONTEXT_MODEL="claude-haiku-4-5"
INGEST_EMBED_MODEL="text-embedding-3-small"
CHAT_MODEL="anthropic/claude-sonnet-4-6"
